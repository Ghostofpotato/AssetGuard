#!/bin/sh
# postrm script for AssetGuard
# AssetGuard, Inc 2015
set -e
DPKG_LIST_FILE="/var/lib/dpkg/info/assetguard-manager.list"

DIR="/var/assetguard-manager"
if [ "$1" = "abort-upgrade" ] || [ "$1" = "failed-upgrade" ]; then
    DIR=$(grep -m 1 -E '/bin/(assetguard-manager-control|assetguard-control)$' "${DPKG_LIST_FILE}" 2>/dev/null \
        | sed -E 's#/bin/(assetguard-manager-control|assetguard-control)$##')

    if [ -z "${DIR}" ] || [ ! -d "${DIR}" ]; then
        exit 0
    fi
fi

ASSETGUARD_TMP_DIR="${DIR}/packages_files/manager_config_files"
ROLLBACK_MARKER="${ASSETGUARD_TMP_DIR}/rollback_prepared"

# If preinst did not prepare rollback state, abort safely.
if [ "$1" = "abort-upgrade" ] || [ "$1" = "failed-upgrade" ]; then
    if [ ! -f "${ROLLBACK_MARKER}" ]; then
        exit 0
    fi
fi

case "$1" in
    remove|failed-upgrade|abort-install|abort-upgrade|disappear)

        if [ -d ${ASSETGUARD_TMP_DIR} ]; then
            rm -rf ${ASSETGUARD_TMP_DIR}
        fi

        # Back up the old configuration files as .save
        if [ ! -d ${DIR}/etc/shared/default ]; then
            mkdir -p ${DIR}/etc/shared/default
        fi

        # Move files from ${DIR}/tmp to ${DIR}/etc
        if [ -f ${DIR}/tmp/conffiles/shared/default/agent.conf ]; then
            mv ${DIR}/tmp/conffiles/shared/default/agent.conf ${DIR}/etc/shared/default/agent.conf.save
        fi

        # Move files from ${DIR}/tmp to ${DIR}/etc
        if [ -f ${DIR}/tmp/conffiles/api.yaml ]; then
            mkdir -p ${DIR}/api/configuration
            mv ${DIR}/tmp/conffiles/api.yaml ${DIR}/api/configuration/api.yaml
        fi

        # If the directory is not empty, copy the files into ${DIR}/etc
        if ls -A ${DIR}/tmp/conffiles > /dev/null 2>&1 ; then
            cp -Rf ${DIR}/tmp/conffiles/* ${DIR}/etc
        fi
        rm -rf ${DIR}/tmp
        if [ "$1" = "remove" ]; then
            rm -rf ${DIR}/ruleset
            rm -rf ${DIR}/var
            rm -rf ${DIR}/logs
            rm -rf ${DIR}/etc/rootcheck
            rm -rf ${DIR}/engine
        fi

        # Delete audisp assetguard plugin if exists
        if [ -e /etc/audit/plugins.d/af_assetguard.conf ]; then
            rm -f -- /etc/audit/plugins.d/af_assetguard.conf
        fi
        if [ -e /etc/audisp/plugins.d/af_assetguard.conf ]; then
            rm -f -- /etc/audisp/plugins.d/af_assetguard.conf
        fi

        # Delete old .save
        find ${DIR}/etc/ -type f  -name "*save" -exec rm -f {} \;

        # Rename the files
        find ${DIR}/etc/ -type f ! -name *shared* -exec mv {} {}.save \;

        if [ -d "${DIR}/api" ]; then
            find "${DIR}/api/" -type f -name "*save" -exec rm -f {} \;
            find "${DIR}/api/" -type f -exec mv {} {}.save \;
        fi

    ;;

    purge)
        if getent passwd assetguard-manager > /dev/null 2>&1 ; then
            deluser assetguard-manager  > /dev/null 2>&1
        fi
        if getent group assetguard-manager > /dev/null 2>&1; then
            delgroup assetguard-manager  > /dev/null 2>&1
        fi
        rm -rf ${DIR}
    ;;

    upgrade)

    ;;

    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 0

    ;;

esac

exit 0
