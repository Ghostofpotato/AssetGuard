# Used only for testing purposes
ASSETGUARD_REVERSE_ORDER_DECODERS=false

# Used for engine standalone
ASSETGUARD_ENGINE_STANDALONE=true

# Sets the logging level.
ASSETGUARD_STANDALONE_LOG_LEVEL=error

# Sets the path to the folder where the assets are located (store).
ASSETGUARD_STORE_PATH=ENV_PATH_PLACEHOLDER/store

# Sets the path to the default outputs folder.
ASSETGUARD_OUTPUTS_PATH=ENV_PATH_PLACEHOLDER/outputs

# Sets the path to the default kvdb folder.
ASSETGUARD_KVDB_IOC_PATH=ENV_PATH_PLACEHOLDER/kvdb-ioc

# Sets the path to the Ruleset Store folder.
ASSETGUARD_CM_RULESET_PATH=ENV_PATH_PLACEHOLDER/content

# Sets the number of threads to be used by the router.
ASSETGUARD_ORCHESTRATOR_THREADS=2

# Set the server configuration
ASSETGUARD_SERVER_THREAD_POOL_SIZE=2
ASSETGUARD_SERVER_EVENT_QUEUE_SIZE=0
ASSETGUARD_SERVER_API_SOCKET=ENV_PATH_PLACEHOLDER/queue/sockets/engine-api.socket
ASSETGUARD_SERVER_API_QUEUE_SIZE=300
ASSETGUARD_SERVER_API_TIMEOUT=10000
ASSETGUARD_SERVER_EVENT_SOCKET=ENV_PATH_PLACEHOLDER/queue/sockets/engine.socket
ASSETGUARD_SERVER_ENRICHED_EVENTS_SOCKET=ENV_PATH_PLACEHOLDER/queue/sockets/queue-http.sock

# Sets the install path to the time zone database.
ASSETGUARD_TZDB_PATH=ENV_PATH_PLACEHOLDER/tzdb
ASSETGUARD_TZDB_AUTO_UPDATE=false

ASSETGUARD_INDEXER_DB_PATH=ENV_PATH_PLACEHOLDER/indexer-connector

# Configure archiver
ASSETGUARD_ARCHIVER_ENABLED=false

# Streamlog
ASSETGUARD_STREAMLOG_BASE_PATH=ENV_PATH_PLACEHOLDER/logs

# Configure geolocation manager
ASSETGUARD_GEO_DB_PATH=ENV_PATH_PLACEHOLDER/geo
ASSETGUARD_GEO_MANIFEST_URL=http://127.0.0.1:8000/manifest.json
ASSETGUARD_GEO_SYNC_INTERVAL=0

# Configure IOC sync
ASSETGUARD_IOC_SYNC_INTERVAL=0
